# Variables de entorno — Quórum Comercio Electrónico

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Credenciales del administrador (solo servidor)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contraseña-segura

# Secreto para sesiones (mínimo 32 caracteres)
SESSION_SECRET=genera-un-secreto-aleatorio-de-al-menos-32-caracteres

# Meta del quórum (opcional, default: 30)
QUORUM_TARGET=30
